{
  "name": "quoteapp-functions",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "18"
  },
  "main": "lib/src/index.js",
  "scripts": {
    "lint": "eslint --ext .ts src test",
    "build": "tsc",
    "test": "mocha --timeout 30000 \"lib/test/**/*.test.js\"",
    "test:build": "npm run build && npm test",
    "emulators:test": "npm run build && firebase emulators:exec --project demo-quoteapp --only functions,firestore,auth \"npm test\"",
    "serve": "npm run build && firebase emulators:start --only functions,firestore,auth"
  },
  "dependencies": {
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.2.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^8.57.1",
    "firebase": "^12.16.0",
    "firebase-tools": "^13.35.1",
    "mocha": "^11.0.1",
    "typescript": "^5.7.2"
  }
}
