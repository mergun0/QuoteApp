<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_v2_background"
    tools:context=".ui.quote.QuoteDetailActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarQuoteDetail"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/home_v2_background"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:menu="@menu/menu_quote_detail"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/home_v2_text_primary"
        app:title=""
        app:titleTextColor="@color/home_v2_text_primary" />

    <ScrollView
        android:id="@+id/scrollQuoteDetail"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarQuoteDetail"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_horizontal_padding"
            android:paddingTop="16dp"
            android:paddingEnd="@dimen/screen_horizontal_padding"
            android:paddingBottom="32dp">

            <LinearLayout
                android:id="@+id/layoutDetailMetadataRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textDetailType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_home_v2_type_badge"
                    android:maxLines="1"
                    android:textColor="@color/home_v2_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:text="ğŸ“š Kitap" />

                <Space
                    android:layout_width="16dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/textDetailUsername"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:ellipsize="end"
                    android:gravity="end|center_vertical"
                    android:maxLines="1"
                    android:minHeight="48dp"
                    android:textColor="@color/home_v2_text_secondary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="@mustafa" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutDetailSpoilerHidden"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_home_v2_spoiler_hidden"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/quote_detail_spoiler_title"
                    android:textColor="@color/home_v2_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/quote_detail_spoiler_description"
                    android:textColor="@color/home_v2_text_secondary"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonShowDetailSpoiler"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:minWidth="0dp"
                    android:text="@string/show_spoiler_detail"
                    android:textColor="@color/home_v2_primary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutDetailQuote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_home_v2_card"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/textDetailQuote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:lineSpacingExtra="8dp"
                    android:textAppearance="@style/TextAppearance.QuoteApp.QuoteText"
                    tools:text="â€œÄ°nsan ancak yÃ¼reÄŸiyle baktÄ±ÄŸÄ± zaman doÄŸruyu gÃ¶rebilir.â€" />
            </LinearLayout>

            <TextView
                android:id="@+id/textDetailTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:textColor="@color/home_v2_text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                tools:text="KÃ¼Ã§Ã¼k Prens" />

            <TextView
                android:id="@+id/textDetailAuthor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/home_v2_text_secondary"
                android:textSize="14sp"
                tools:text="Antoine de Saint-ExupÃ©ry" />

            <TextView
                android:id="@+id/textDetailCharacter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/home_v2_text_secondary"
                android:textSize="14sp"
                android:visibility="gone"
                tools:text="Karakter: KÃ¼Ã§Ã¼k Prens"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/textDetailSeries"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/home_v2_text_secondary"
                android:textSize="14sp"
                android:visibility="gone"
                tools:text="Sezon 1 â€¢ BÃ¶lÃ¼m 3"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/textDetailCreatedAt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textColor="@color/home_v2_text_secondary"
                android:textSize="13sp"
                tools:text="PaylaÅŸÄ±lma tarihi: 6 Temmuz 2026 â€¢ 14:30" />

            <TextView
                android:id="@+id/textDetailTags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textColor="@color/home_v2_secondary"
                android:textSize="14sp"
                android:visibility="gone"
                tools:text="#hayat  #umut"
                tools:visibility="visible" />

            <LinearLayout
                android:id="@+id/layoutDetailActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_home_v2_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonDetailFavorite"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/favorite"
                    android:minWidth="0dp"
                    android:text=""
                    android:textColor="@color/home_v2_text_secondary"
                    app:icon="@drawable/ic_favorite"
                    app:iconGravity="textStart"
                    app:iconTint="@color/home_v2_text_secondary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonDetailComment"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:text="0"
                    android:textColor="@color/home_v2_text_secondary"
                    app:icon="@drawable/ic_comment"
                    app:iconGravity="textStart"
                    app:iconTint="@color/home_v2_text_secondary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonDetailSave"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/save_quote"
                    android:minWidth="0dp"
                    android:text=""
                    android:textColor="@color/home_v2_text_secondary"
                    app:icon="@drawable/ic_bookmark"
                    app:iconGravity="textStart"
                    app:iconTint="@color/home_v2_text_secondary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonDetailShare"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/share"
                    android:minWidth="0dp"
                    android:text=""
                    android:textColor="@color/home_v2_primary"
                    app:icon="@drawable/ic_share"
                    app:iconGravity="textStart"
                    app:iconTint="@color/home_v2_primary" />
            </LinearLayout>

            <TextView
                android:id="@+id/textDetailStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:textColor="@color/home_v2_error"
                android:textSize="14sp"
                android:visibility="gone"
                tools:text="Ä°ÅŸlem tamamlanamadÄ±."
                tools:visibility="visible" />

            <LinearLayout
                android:id="@+id/layoutDetailCommentsPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_home_v2_card"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/quote_detail_comments_title"
                    android:textColor="@color/home_v2_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/quote_detail_comments_empty"
                    android:textColor="@color/home_v2_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/quote_detail_comments_cta"
                    android:textColor="@color/home_v2_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutDetailSimilarQuotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_home_v2_card"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/quote_detail_similar_title"
                    android:textColor="@color/home_v2_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/quote_detail_similar_empty"
                    android:textColor="@color/home_v2_text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/textDetailSpoilerBadge"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonDetailReport"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layoutDetailOwnerActions"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonDetailEdit"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="1dp"
                    android:layout_height="1dp"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonDetailDelete"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="1dp"
                    android:layout_height="1dp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <ProgressBar
        android:id="@+id/progressQuoteDetail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/home_v2_primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarQuoteDetail" />

    <TextView
        android:id="@+id/textQuoteDetailError"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/screen_horizontal_padding"
        android:layout_marginEnd="@dimen/screen_horizontal_padding"
        android:gravity="center"
        android:textColor="@color/home_v2_error"
        android:textSize="15sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarQuoteDetail"
        tools:text="AlÄ±ntÄ± yÃ¼klenemedi."
        tools:visibility="visible" />
</androidx.constraintlayout.widget.ConstraintLayout>

