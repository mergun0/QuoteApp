<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/quote_background"
    tools:context=".ui.quote.QuoteDetailActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarQuoteDetail"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/quote_surface"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/quote_text_primary"
        app:title="@string/quote_detail_title"
        app:titleTextColor="@color/quote_text_primary" />

    <ScrollView
        android:id="@+id/scrollQuoteDetail"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarQuoteDetail"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textDetailType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_type_badge"
                    android:textColor="@color/quote_primary_dark"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="KİTAP" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/textDetailSpoilerBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_spoiler_badge"
                    android:text="@string/spoiler_warning"
                    android:textColor="@color/quote_status_error"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:visibility="visible" />
            </LinearLayout>

            <TextView
                android:id="@+id/textDetailUsername"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:textColor="@color/quote_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="@string/username" />

            <TextView
                android:id="@+id/textDetailTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/quote_text_primary"
                android:textSize="26sp"
                android:textStyle="bold"
                tools:text="Küçük Prens" />

            <TextView
                android:id="@+id/textDetailAuthor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/quote_text_secondary"
                android:textSize="15sp"
                tools:text="Antoine de Saint-Exupéry" />

            <TextView
                android:id="@+id/textDetailCharacter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/quote_text_secondary"
                android:textSize="14sp"
                android:visibility="gone"
                tools:text="Karakter: Küçük Prens"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/textDetailSeries"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/quote_text_secondary"
                android:textSize="14sp"
                android:visibility="gone"
                tools:text="Sezon 1 • Bölüm 3"
                tools:visibility="visible" />

            <LinearLayout
                android:id="@+id/layoutDetailQuote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_detail_quote"
                android:orientation="vertical"
                android:padding="22dp">

                <TextView
                    android:id="@+id/textDetailQuote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:lineSpacingExtra="5dp"
                    android:textColor="@color/quote_text_primary"
                    android:textSize="23sp"
                    tools:text="“İnsan ancak yüreğiyle baktığı zaman doğruyu görebilir.”" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutDetailSpoilerHidden"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_spoiler_hidden"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/spoiler_hidden_message"
                    android:textColor="@color/quote_text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonShowDetailSpoiler"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/show_spoiler_detail" />
            </LinearLayout>

            <TextView
                android:id="@+id/textDetailTags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:textColor="@color/quote_primary"
                android:textSize="14sp"
                android:visibility="gone"
                tools:text="#hayat  #umut"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/textDetailCreatedAt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:textColor="@color/quote_text_secondary"
                android:textSize="13sp"
                tools:text="6 Temmuz 2026 • 14:30" />

            <TextView
                android:id="@+id/textDetailStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:textColor="@color/quote_status_error"
                android:textSize="14sp"
                android:visibility="gone"
                tools:text="İşlem tamamlanamadı."
                tools:visibility="visible" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonDetailFavorite"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="22dp"
                android:text="@string/favorite"
                app:cornerRadius="15dp"
                app:icon="@drawable/ic_favorite" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonDetailShare"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:text="@string/share"
                app:cornerRadius="15dp"
                app:icon="@drawable/ic_share" />

            <LinearLayout
                android:id="@+id/layoutDetailOwnerActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:visibility="gone"
                tools:visibility="visible">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonDetailEdit"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:text="@string/edit"
                    app:icon="@drawable/ic_edit" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonDetailDelete"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:text="@string/delete"
                    android:textColor="@color/quote_status_error"
                    app:icon="@drawable/ic_delete"
                    app:iconTint="@color/quote_status_error"
                    app:strokeColor="@color/quote_status_error" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <ProgressBar
        android:id="@+id/progressQuoteDetail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarQuoteDetail" />

    <TextView
        android:id="@+id/textQuoteDetailError"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:gravity="center"
        android:textColor="@color/quote_status_error"
        android:textSize="15sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarQuoteDetail"
        tools:text="Alıntı yüklenemedi."
        tools:visibility="visible" />

</androidx.constraintlayout.widget.ConstraintLayout>
