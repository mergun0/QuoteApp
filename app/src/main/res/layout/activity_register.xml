<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/quote_background"
    android:fillViewport="true"
    tools:context=".ui.auth.RegisterActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingTop="48dp"
        android:paddingEnd="28dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/register_title"
            android:textColor="@color/quote_text_primary"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="28dp"
            android:text="@string/register_subtitle"
            android:textColor="@color/quote_text_secondary"
            android:textSize="15sp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutRegisterUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/username"
            app:boxBackgroundMode="outline"
            app:boxBackgroundColor="@color/quote_surface"
            app:boxStrokeColor="@color/quote_outline"
            app:hintTextColor="@color/quote_text_secondary">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editRegisterUsername"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/quote_text_primary"
                android:textColorHint="@color/quote_text_secondary"
                android:inputType="text"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutRegisterEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:hint="@string/email"
            app:boxBackgroundMode="outline"
            app:boxBackgroundColor="@color/quote_surface"
            app:boxStrokeColor="@color/quote_outline"
            app:hintTextColor="@color/quote_text_secondary">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editRegisterEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/quote_text_primary"
                android:textColorHint="@color/quote_text_secondary"
                android:inputType="textEmailAddress"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutRegisterPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:hint="@string/password"
            app:boxBackgroundMode="outline"
            app:boxBackgroundColor="@color/quote_surface"
            app:boxStrokeColor="@color/quote_outline"
            app:hintTextColor="@color/quote_text_secondary"
            app:endIconMode="password_toggle">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editRegisterPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/quote_text_primary"
                android:textColorHint="@color/quote_text_secondary"
                android:inputType="textPassword"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutRegisterConfirmPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:hint="@string/password_repeat"
            app:boxBackgroundMode="outline"
            app:boxBackgroundColor="@color/quote_surface"
            app:boxStrokeColor="@color/quote_outline"
            app:hintTextColor="@color/quote_text_secondary"
            app:endIconMode="password_toggle">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editRegisterConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/quote_text_primary"
                android:textColorHint="@color/quote_text_secondary"
                android:inputType="textPassword"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/textRegisterStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:textColor="@color/quote_status_error"
            android:textSize="14sp"
            android:visibility="gone"
            android:accessibilityLiveRegion="polite"
            tools:text="Lütfen alanları kontrol edin."
            tools:visibility="visible" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonRegister"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="@string/register"
            android:textSize="16sp"
            app:cornerRadius="16dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:orientation="horizontal">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/already_have_account"
                android:textColor="@color/quote_text_secondary" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonBackToLogin"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:text="@string/login" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
