<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/quote_background"
    tools:context=".ui.profile.AchievementsActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarAchievements"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/quote_surface"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/quote_text_primary"
        app:title="@string/all_achievements"
        app:titleTextColor="@color/quote_text_primary" />

    <LinearLayout
        android:id="@+id/layoutAchievementsHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="18dp"
        android:paddingEnd="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarAchievements">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/quote_surface"
            app:cardCornerRadius="22dp"
            app:cardElevation="1dp"
            app:strokeColor="#E2D8DC"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="18dp">

                <FrameLayout
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_achievement_icon"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/all_achievements"
                        android:src="@drawable/ic_achievement"
                        app:tint="@color/quote_primary" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textAchievementsLevel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/quote_text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        tools:text="Seviye 1" />

                    <TextView
                        android:id="@+id/textAchievementsXp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/quote_text_secondary"
                        android:textSize="13sp"
                        tools:text="0 XP" />
                </LinearLayout>

                <TextView
                    android:id="@+id/textAchievementsUnlockedCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chip_soft"
                    android:paddingStart="12dp"
                    android:paddingTop="7dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="7dp"
                    android:textColor="@color/quote_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="0 başarım" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupAchievementFilters"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:checkedChip="@id/chipAchievementAll"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAchievementAll"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_all" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAchievementUnlocked"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/achievement_filter_unlocked" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAchievementLocked"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/achievement_filter_locked" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAchievementSocial"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/achievement_filter_social" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAchievementQuote"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/achievement_filter_quote" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAchievementModeration"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/achievement_filter_moderation" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAchievementType"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/achievement_filter_type" />
            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerAchievements"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="20dp"
        android:paddingTop="10dp"
        android:paddingEnd="20dp"
        android:paddingBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutAchievementsHeader"
        tools:listitem="@layout/item_achievement" />

    <ProgressBar
        android:id="@+id/progressAchievements"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutAchievementsHeader"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/textAchievementsEmpty"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:gravity="center"
        android:text="@string/achievement_list_empty"
        android:textColor="@color/quote_text_secondary"
        android:textSize="15sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutAchievementsHeader"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/textAchievementsError"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:gravity="center"
        android:textColor="@color/quote_status_error"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutAchievementsHeader"
        tools:text="Başarımlar yüklenemedi."
        tools:visibility="visible" />
</androidx.constraintlayout.widget.ConstraintLayout>
