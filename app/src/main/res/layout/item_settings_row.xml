<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingEnd="16dp">

    <TextView
        android:id="@+id/textSettingsRowIcon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:gravity="center"
        android:textColor="@color/home_v2_text_primary"
        android:textSize="22sp"
        tools:text="⚙️" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textSettingsRowTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/home_v2_text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="Hesap Bilgileri" />

        <TextView
            android:id="@+id/textSettingsRowSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/home_v2_text_secondary"
            android:textSize="12sp"
            tools:text="E-posta ve kullanıcı bilgileri" />
    </LinearLayout>

    <TextView
        android:id="@+id/textSettingsRowIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="@string/profile_menu_chevron"
        android:textColor="@color/home_v2_hint"
        android:textSize="18sp"
        tools:text="›" />
</LinearLayout>
