<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_v2_background"
    tools:context=".ui.profile.LegalDocumentActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarLegalDocument"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@color/home_v2_background"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/home_v2_text_primary"
        app:titleTextColor="@color/home_v2_text_primary" />

    <ScrollView
        android:id="@+id/scrollLegalDocument"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarLegalDocument">

        <TextView
            android:id="@+id/textLegalDocumentContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="6dp"
            android:textColor="@color/home_v2_text_secondary"
            android:textSize="15sp"
            tools:text="Yasal metin burada gösterilir." />
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
