<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/quote_surface"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#E2D8DC"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/textStatValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/quote_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            tools:text="12" />

        <TextView
            android:id="@+id/textStatLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/quote_text_secondary"
            android:textSize="13sp"
            tools:text="Toplam" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
