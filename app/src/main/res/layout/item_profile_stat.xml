<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/quote_surface"
    app:cardCornerRadius="18dp"
    app:cardElevation="1dp"
    app:rippleColor="@color/bottom_nav_ripple"
    app:strokeColor="#E2D8DC"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="92dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="14dp"
        android:paddingEnd="12dp"
        android:paddingBottom="14dp">

        <TextView
            android:id="@+id/textStatValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:textColor="@color/quote_primary"
            android:textSize="25sp"
            android:textStyle="bold"
            tools:text="12" />

        <TextView
            android:id="@+id/textStatLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="2"
            android:textColor="@color/quote_text_secondary"
            android:textSize="12sp"
            android:textStyle="bold"
            tools:text="Toplam" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
