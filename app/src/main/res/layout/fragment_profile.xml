<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_v2_background"
    android:fillViewport="true"
    tools:context=".ui.profile.ProfileFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textProfileAvatar"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:background="@drawable/bg_home_v2_avatar"
                android:gravity="center"
                android:textColor="@color/home_v2_text_primary"
                android:textSize="32sp"
                android:textStyle="bold"
                tools:text="M" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textProfileUsername"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/home_v2_text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    tools:text="Mustafa" />

                <TextView
                    android:id="@+id/textProfileHandle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/home_v2_text_secondary"
                    android:textSize="14sp"
                    tools:text="@mustafa" />

                <TextView
                    android:id="@+id/textProfileEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    tools:text="kullanici@example.com" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardProfileLevel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/home_v2_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/home_v2_divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/textProfileLevel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/home_v2_text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            tools:text="⭐ Seviye 12" />

                        <TextView
                            android:id="@+id/textProfileNextLevel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/home_v2_text_secondary"
                            android:textSize="13sp"
                            tools:text="Sonraki: Seviye 13" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/textProfileAchievementCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_home_v2_type_badge"
                        android:paddingStart="12dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="8dp"
                        android:textColor="@color/home_v2_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        tools:text="🏆 18 Başarım" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressProfileXp"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="16dp"
                    android:max="100"
                    android:progress="0"
                    android:progressBackgroundTint="@color/home_v2_divider"
                    android:progressTint="@color/home_v2_secondary" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/textProfileXp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/home_v2_text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        tools:text="1240 / 1800 XP" />

                    <TextView
                        android:id="@+id/textProfileXpProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/home_v2_accent"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        tools:text="560 XP kaldı" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:columnCount="2"
            android:rowCount="2"
            android:useDefaultMargins="false">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProfileLikes"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/home_v2_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/home_v2_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="♥"
                        android:textColor="@color/home_v2_error"
                        android:textSize="24sp" />

                    <TextView
                        android:id="@+id/textProfileLikesValue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="0"
                        android:textColor="@color/home_v2_text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        tools:text="128" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/profile_stat_total_likes"
                        android:textColor="@color/home_v2_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProfileQuotes"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/home_v2_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/home_v2_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✎"
                        android:textColor="@color/home_v2_primary"
                        android:textSize="24sp" />

                    <TextView
                        android:id="@+id/textProfileQuotesValue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="0"
                        android:textColor="@color/home_v2_text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        tools:text="42" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/profile_stat_total_quotes"
                        android:textColor="@color/home_v2_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProfileAchievementsStat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/home_v2_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/home_v2_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="★"
                        android:textColor="@color/home_v2_accent"
                        android:textSize="24sp" />

                    <TextView
                        android:id="@+id/textProfileAchievementsStatValue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="0"
                        android:textColor="@color/home_v2_text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        tools:text="18" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/profile_stat_unlocked_achievements"
                        android:textColor="@color/home_v2_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProfileSaved"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginStart="8dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/home_v2_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/home_v2_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="◆"
                        android:textColor="@color/home_v2_secondary"
                        android:textSize="24sp" />

                    <TextView
                        android:id="@+id/textProfileSavedValue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="0"
                        android:textColor="@color/home_v2_text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        tools:text="7" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/profile_stat_saved_quotes"
                        android:textColor="@color/home_v2_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </GridLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardProfileLastAchievement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="@color/home_v2_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/home_v2_divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_last_achievement_title"
                    android:textColor="@color/home_v2_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/textProfileLastAchievementIcon"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_home_v2_avatar"
                        android:gravity="center"
                        android:text="@string/profile_achievement_icon_placeholder"
                        android:textSize="24sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/textProfileLastAchievementTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/home_v2_text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            tools:text="İlk Satır" />

                        <TextView
                            android:id="@+id/textProfileLastAchievementDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/home_v2_text_secondary"
                            android:textSize="13sp"
                            tools:text="İlk alıntını paylaşarak koleksiyonunu başlattın." />

                        <TextView
                            android:id="@+id/textProfileLastAchievementMeta"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textColor="@color/home_v2_accent"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            tools:text="+25 XP • 09.07.2026" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardProfileNextAchievement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="@color/home_v2_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/home_v2_divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_next_achievement_title"
                    android:textColor="@color/home_v2_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/textProfileNextAchievementIcon"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_home_v2_avatar"
                        android:gravity="center"
                        android:text="@string/profile_next_achievement_icon_placeholder"
                        android:textSize="24sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/textProfileNextAchievementTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/home_v2_text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            tools:text="Düzenli Paylaşımcı" />

                        <TextView
                            android:id="@+id/textProfileNextAchievementDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/home_v2_text_secondary"
                            android:textSize="13sp"
                            tools:text="10 alıntı paylaş." />

                        <ProgressBar
                            android:id="@+id/progressProfileNextAchievement"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:layout_marginTop="12dp"
                            android:max="100"
                            android:progress="0"
                            android:progressBackgroundTint="@color/home_v2_divider"
                            android:progressTint="@color/home_v2_primary" />

                        <TextView
                            android:id="@+id/textProfileNextAchievementProgress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textColor="@color/home_v2_accent"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            tools:text="4 / 10" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardProfileAchievements"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/home_v2_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/home_v2_divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/achievements"
                    android:textColor="@color/home_v2_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerProfileAchievements"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:layout_marginTop="12dp"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:orientation="horizontal"
                    tools:listitem="@layout/item_achievement_preview" />

                <TextView
                    android:id="@+id/textProfileAchievementEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="@string/achievement_empty"
                    android:textColor="@color/home_v2_text_secondary"
                    android:textSize="13sp"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonProfileAllAchievements"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:text="@string/all_achievements"
                    android:textColor="@color/home_v2_primary"
                    app:cornerRadius="16dp"
                    app:strokeColor="@color/home_v2_primary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <ProgressBar
            android:id="@+id/progressProfile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:indeterminateTint="@color/home_v2_primary" />

        <TextView
            android:id="@+id/textProfileStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:accessibilityLiveRegion="polite"
            android:gravity="center"
            android:textColor="@color/home_v2_error"
            android:textSize="14sp"
            android:visibility="gone"
            tools:text="Profil bilgileri yüklenemedi."
            tools:visibility="visible" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardProfileMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/home_v2_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/home_v2_divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <include
                    android:id="@+id/menuProfileFavorites"
                    layout="@layout/item_profile_menu_row" />

                <include
                    android:id="@+id/menuProfileAchievements"
                    layout="@layout/item_profile_menu_row" />

                <include
                    android:id="@+id/menuProfileSettings"
                    layout="@layout/item_profile_menu_row" />

                <include
                    android:id="@+id/menuProfileAbout"
                    layout="@layout/item_profile_menu_row" />

                <include
                    android:id="@+id/buttonLogout"
                    layout="@layout/item_profile_menu_row" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/textProfileFooterApp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:text="@string/app_name"
            android:textColor="@color/home_v2_text_secondary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textProfileFooterVersion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="@string/profile_app_version"
            android:textColor="@color/home_v2_hint"
            android:textSize="12sp" />
    </LinearLayout>
</ScrollView>
