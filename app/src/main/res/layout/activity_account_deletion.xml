<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_v2_background"
    tools:context=".ui.profile.AccountDeletionActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarAccountDeletion"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@color/home_v2_background"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/home_v2_text_primary"
        app:title="@string/account_delete_title"
        app:titleTextColor="@color/home_v2_text_primary" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarAccountDeletion">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_home_v2_card"
                android:padding="16dp"
                android:text="@string/account_delete_warning"
                android:textColor="@color/home_v2_text_primary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/textDeletionStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_home_v2_card"
                android:padding="16dp"
                android:textColor="@color/quote_status_success"
                android:textSize="15sp"
                android:visibility="gone"
                tools:text="@string/account_delete_pending_message"
                tools:visibility="visible" />

            <LinearLayout
                android:id="@+id/containerDeletionForm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_home_v2_card"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutDeletionPassword"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/account_delete_password"
                    app:boxStrokeColor="@color/home_v2_primary"
                    app:hintTextColor="@color/home_v2_text_secondary"
                    app:passwordToggleEnabled="true">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editDeletionPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textColor="@color/home_v2_text_primary"
                        android:textColorHint="@color/home_v2_text_secondary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/account_delete_reason"
                    app:boxStrokeColor="@color/home_v2_primary"
                    app:hintTextColor="@color/home_v2_text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editDeletionReason"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:maxLength="500"
                        android:minLines="2"
                        android:textColor="@color/home_v2_text_primary"
                        android:textColorHint="@color/home_v2_text_secondary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/account_delete_confirmation_hint"
                    app:boxStrokeColor="@color/home_v2_error"
                    app:hintTextColor="@color/home_v2_text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editDeletionConfirmation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapCharacters"
                        android:singleLine="true"
                        android:textColor="@color/home_v2_text_primary"
                        android:textColorHint="@color/home_v2_text_secondary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonRequestDeletion"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="@color/home_v2_error"
                    android:text="@string/account_delete_request_button"
                    android:textAllCaps="false"
                    android:textColor="@color/home_v2_text_primary"
                    app:cornerRadius="16dp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonDeletionSignOut"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:text="@string/logout"
                android:textAllCaps="false"
                android:textColor="@color/home_v2_text_primary"
                app:cornerRadius="16dp"
                app:strokeColor="@color/home_v2_divider" />
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
