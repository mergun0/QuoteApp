<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginTop="8dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/home_v2_card"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp"
    app:rippleColor="#336C63FF"
    app:strokeColor="@color/home_v2_divider"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textCardType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_home_v2_type_badge"
                android:textColor="@color/home_v2_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="KİTAP" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/textCardSpoiler"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_home_v2_spoiler_badge"
                android:text="@string/spoiler_warning"
                android:textColor="@color/home_v2_error"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:visibility="visible" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutCardUser"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone"
            tools:visibility="visible">

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_home_v2_avatar"
                android:padding="8dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/nav_profile"
                    android:src="@drawable/ic_person"
                    app:tint="@color/home_v2_text_primary" />
            </FrameLayout>

            <TextView
                android:id="@+id/textCardUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:textColor="@color/home_v2_text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="@kullanici" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/quoteTextContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textCardQuote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/home_v2_text_primary"
                android:textSize="19sp"
                android:textStyle="bold"
                tools:text="“İnsan ancak yüreğiyle baktığı zaman doğruyu görebilir.”" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/spoilerHiddenContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_home_v2_spoiler_hidden"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/spoiler_hidden_message"
                android:textColor="@color/home_v2_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/showSpoilerButton"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:minWidth="0dp"
                android:text="@string/show_spoiler"
                android:textColor="@color/home_v2_primary" />
        </LinearLayout>

        <TextView
            android:id="@+id/textCardTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="@color/home_v2_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Küçük Prens" />

        <TextView
            android:id="@+id/textCardAuthor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/home_v2_text_secondary"
            android:textSize="14sp"
            tools:text="Antoine de Saint-Exupéry" />

        <TextView
            android:id="@+id/textCardCharacter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/home_v2_text_secondary"
            android:textSize="13sp"
            android:visibility="gone"
            tools:text="Karakter: Küçük Prens"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/textCardSeries"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/home_v2_text_secondary"
            android:textSize="13sp"
            android:visibility="gone"
            tools:text="Sezon 2 • Bölüm 4"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/textCardTags"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/home_v2_secondary"
            android:textSize="13sp"
            android:visibility="gone"
            tools:text="#umut  #hayat"
            tools:visibility="visible" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonFavoriteQuote"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/favorite"
                android:textColor="@color/home_v2_text_secondary"
                app:icon="@drawable/ic_favorite"
                app:iconGravity="textStart"
                app:iconTint="@color/home_v2_text_secondary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonShareQuote"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/share"
                android:textColor="@color/home_v2_primary"
                app:icon="@drawable/ic_share"
                app:iconGravity="textStart"
                app:iconTint="@color/home_v2_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonMoreQuote"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/more_actions"
                android:minWidth="0dp"
                android:text=""
                app:icon="@drawable/ic_more_vert"
                app:iconGravity="textStart"
                app:iconTint="@color/home_v2_text_secondary" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
