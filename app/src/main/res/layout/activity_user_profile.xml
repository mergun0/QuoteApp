<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_v2_background"
    tools:context=".ui.profile.UserProfileActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarUserProfile"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/home_v2_background"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/home_v2_text_primary"
        app:title="@string/user_profile_title"
        app:titleTextColor="@color/home_v2_text_primary" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollUserProfile"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarUserProfile"
        tools:visibility="visible">

        <LinearLayout
            android:id="@+id/layoutUserProfileContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textUserProfileAvatar"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:background="@drawable/bg_home_v2_avatar"
                    android:gravity="center"
                    android:textColor="@color/home_v2_text_primary"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    tools:text="M" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textUserProfileDisplayName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/home_v2_text_primary"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        tools:text="Mustafa" />

                    <TextView
                        android:id="@+id/textUserProfileUsername"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/home_v2_text_secondary"
                        android:textSize="14sp"
                        tools:text="@mustafa" />

                    <TextView
                        android:id="@+id/textUserProfileJoinedAt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/home_v2_hint"
                        android:textSize="13sp"
                        android:visibility="gone"
                        tools:text="Katılım: Temmuz 2026"
                        tools:visibility="visible" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonFollowComingSoon"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:text="@string/follow_coming_soon"
                android:textColor="@color/home_v2_primary"
                app:cornerRadius="16dp"
                app:strokeColor="@color/home_v2_primary" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardUserProfileLevel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="@color/home_v2_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/home_v2_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/textUserProfileLevel"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/home_v2_text_primary"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                tools:text="⭐ Seviye 12" />

                            <TextView
                                android:id="@+id/textUserProfileNextLevel"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textColor="@color/home_v2_text_secondary"
                                android:textSize="13sp"
                                tools:text="Sonraki: Seviye 13" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/textUserProfileAchievementCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_home_v2_type_badge"
                            android:paddingStart="12dp"
                            android:paddingTop="8dp"
                            android:paddingEnd="12dp"
                            android:paddingBottom="8dp"
                            android:textColor="@color/home_v2_primary"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            tools:text="🏆 18 Başarım" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressUserProfileXp"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="16dp"
                        android:max="100"
                        android:progress="0"
                        android:progressBackgroundTint="@color/home_v2_divider"
                        android:progressTint="@color/home_v2_secondary" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/textUserProfileXp"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="@color/home_v2_text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="1240 / 1800 XP" />

                        <TextView
                            android:id="@+id/textUserProfileXpProgress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/home_v2_accent"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="560 XP kaldı" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:columnCount="2"
                android:rowCount="2"
                android:useDefaultMargins="false">

                <include
                    android:id="@+id/userStatLikes"
                    layout="@layout/item_user_profile_v2_stat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="12dp" />

                <include
                    android:id="@+id/userStatTotal"
                    layout="@layout/item_user_profile_v2_stat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="12dp" />

                <include
                    android:id="@+id/userStatAchievements"
                    layout="@layout/item_user_profile_v2_stat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="8dp" />

                <include
                    android:id="@+id/userStatSaved"
                    layout="@layout/item_user_profile_v2_stat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="8dp" />
            </GridLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardUserProfileLastAchievement"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/home_v2_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/home_v2_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/profile_last_achievement_title"
                        android:textColor="@color/home_v2_text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textUserProfileLastAchievementTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textColor="@color/home_v2_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        tools:text="İlk Satır" />

                    <TextView
                        android:id="@+id/textUserProfileLastAchievementDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/home_v2_text_secondary"
                        android:textSize="13sp"
                        tools:text="İlk alıntısını paylaştı." />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardUserProfileNextAchievement"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/home_v2_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/home_v2_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/profile_next_achievement_title"
                        android:textColor="@color/home_v2_text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textUserProfileNextAchievementTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textColor="@color/home_v2_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        tools:text="Düzenli Paylaşımcı" />

                    <TextView
                        android:id="@+id/textUserProfileNextAchievementDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/home_v2_text_secondary"
                        android:textSize="13sp"
                        tools:text="10 alıntı paylaş." />

                    <ProgressBar
                        android:id="@+id/progressUserProfileNextAchievement"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="12dp"
                        android:max="100"
                        android:progress="0"
                        android:progressBackgroundTint="@color/home_v2_divider"
                        android:progressTint="@color/home_v2_primary" />

                    <TextView
                        android:id="@+id/textUserProfileNextAchievementProgress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/home_v2_accent"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        tools:text="4 / 10" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardUserProfileAchievements"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/home_v2_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/home_v2_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/achievements"
                        android:textColor="@color/home_v2_text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerUserProfileAchievements"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:layout_marginTop="12dp"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        android:orientation="horizontal"
                        tools:listitem="@layout/item_achievement_preview" />

                    <TextView
                        android:id="@+id/textUserProfileAchievementEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:text="@string/user_achievements_empty"
                        android:textColor="@color/home_v2_text_secondary"
                        android:textSize="13sp"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonUserProfileAllAchievements"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:text="@string/all_achievements"
                        android:textColor="@color/home_v2_primary"
                        app:cornerRadius="16dp"
                        app:strokeColor="@color/home_v2_primary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/textUserProfileStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:textColor="@color/home_v2_error"
                android:textSize="13sp"
                android:visibility="gone"
                tools:text="İşlem tamamlanamadı."
                tools:visibility="visible" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/user_profile_quotes_title"
                android:textColor="@color/home_v2_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textEmptyUserQuotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                android:gravity="center"
                android:text="@string/user_has_no_quotes"
                android:textColor="@color/home_v2_text_secondary"
                android:textSize="15sp"
                android:visibility="gone"
                tools:visibility="visible" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerUserQuotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                tools:itemCount="3"
                tools:listitem="@layout/item_quote_home" />

            <ProgressBar
                android:id="@+id/progressUserQuotesLoadMore"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"
                android:indeterminateTint="@color/home_v2_primary"
                android:visibility="gone"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/textUserQuotesNoMore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:text="@string/no_more_quotes"
                android:textColor="@color/home_v2_text_secondary"
                android:textSize="12sp"
                android:visibility="gone"
                tools:visibility="visible" />

            <LinearLayout
                android:id="@+id/layoutOwnProfileActions"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonEditUserProfile"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="1dp"
                    android:layout_height="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonUserProfileLogout"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="1dp"
                    android:layout_height="1dp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <ProgressBar
        android:id="@+id/progressUserProfile"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/home_v2_primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarUserProfile" />

    <TextView
        android:id="@+id/textUserProfileError"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:gravity="center"
        android:textColor="@color/home_v2_error"
        android:textSize="15sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarUserProfile"
        tools:text="Profil yüklenemedi."
        tools:visibility="visible" />
</androidx.constraintlayout.widget.ConstraintLayout>
