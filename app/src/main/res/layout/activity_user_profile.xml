<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/quote_background"
    tools:context=".ui.profile.UserProfileActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarUserProfile"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/quote_surface"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/quote_text_primary"
        app:title="@string/user_profile_title"
        app:titleTextColor="@color/quote_text_primary" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollUserProfile"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarUserProfile"
        tools:visibility="visible">

        <LinearLayout
            android:id="@+id/layoutUserProfileContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="16dp"
            android:paddingEnd="20dp"
            android:paddingBottom="24dp"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/bg_profile_avatar"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/nav_profile"
                        android:src="@drawable/ic_person"
                        app:tint="@color/quote_primary" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textUserProfileUsername"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/quote_text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        tools:text="@string/username" />

                    <TextView
                        android:id="@+id/textUserProfileJoinedAt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:textColor="@color/quote_text_secondary"
                        android:textSize="13sp"
                        android:visibility="gone"
                        tools:text="Katılım: Temmuz 2026"
                        tools:visibility="visible" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <include
                    android:id="@+id/userStatTotal"
                    layout="@layout/item_profile_stat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1" />

                <include
                    android:id="@+id/userStatMovies"
                    layout="@layout/item_profile_stat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1" />

                <include
                    android:id="@+id/userStatSeries"
                    layout="@layout/item_profile_stat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1" />

                <include
                    android:id="@+id/userStatBooks"
                    layout="@layout/item_profile_stat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1" />
            </LinearLayout>

            <include
                android:id="@+id/userStatLikes"
                layout="@layout/item_profile_stat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardUserProfileAchievements"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/quote_surface"
                app:cardCornerRadius="22dp"
                app:cardElevation="1dp"
                app:strokeColor="#E2D8DC"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/textUserProfileLevel"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/quote_text_primary"
                                android:textSize="19sp"
                                android:textStyle="bold"
                                tools:text="Seviye 1" />

                            <TextView
                                android:id="@+id/textUserProfileXp"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textColor="@color/quote_text_secondary"
                                android:textSize="13sp"
                                tools:text="0 XP" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/textUserProfileAchievementCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_chip_soft"
                            android:paddingStart="12dp"
                            android:paddingTop="7dp"
                            android:paddingEnd="12dp"
                            android:paddingBottom="7dp"
                            android:textColor="@color/quote_primary"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            tools:text="0 başarım" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressUserProfileXp"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="16dp"
                        android:max="100"
                        android:progress="0"
                        android:progressBackgroundTint="@color/bottom_nav_ripple"
                        android:progressTint="@color/quote_primary" />

                    <TextView
                        android:id="@+id/textUserProfileXpProgress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/quote_text_secondary"
                        android:textSize="12sp"
                        tools:text="0 / 100 XP" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/achievements"
                        android:textColor="@color/quote_text_primary"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerUserProfileAchievements"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:layout_marginTop="10dp"
                        android:clipToPadding="false"
                        android:orientation="horizontal"
                        tools:listitem="@layout/item_achievement_preview" />

                    <TextView
                        android:id="@+id/textUserProfileAchievementEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:text="@string/achievement_empty"
                        android:textColor="@color/quote_text_secondary"
                        android:textSize="13sp"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonUserProfileAllAchievements"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="10dp"
                        android:text="@string/all_achievements" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/layoutOwnProfileActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:visibility="gone"
                tools:visibility="visible">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonEditUserProfile"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:text="@string/edit_profile" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonUserProfileLogout"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="5dp"
                    android:layout_weight="1"
                    android:text="@string/logout"
                    android:textColor="@color/quote_status_error"
                    app:strokeColor="@color/quote_status_error" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonFollowComingSoon"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:text="@string/follow_coming_soon"
                android:visibility="gone"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/textUserProfileStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:textColor="@color/quote_status_error"
                android:textSize="13sp"
                android:visibility="gone"
                tools:text="İşlem tamamlanamadı."
                tools:visibility="visible" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/user_quotes"
                android:textColor="@color/quote_text_primary"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textEmptyUserQuotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                android:gravity="center"
                android:text="@string/user_has_no_quotes"
                android:textColor="@color/quote_text_secondary"
                android:textSize="15sp"
                android:visibility="gone"
                tools:visibility="visible" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerUserQuotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingTop="6dp"
                android:paddingBottom="8dp"
                tools:itemCount="3"
                tools:listitem="@layout/item_quote" />

            <ProgressBar
                android:id="@+id/progressUserQuotesLoadMore"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/textUserQuotesNoMore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="8dp"
                android:text="@string/no_more_quotes"
                android:textColor="@color/quote_text_secondary"
                android:textSize="12sp"
                android:visibility="gone"
                tools:visibility="visible" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <ProgressBar
        android:id="@+id/progressUserProfile"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarUserProfile" />

    <TextView
        android:id="@+id/textUserProfileError"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:gravity="center"
        android:textColor="@color/quote_status_error"
        android:textSize="15sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarUserProfile"
        tools:text="Profil yüklenemedi."
        tools:visibility="visible" />

</androidx.constraintlayout.widget.ConstraintLayout>
