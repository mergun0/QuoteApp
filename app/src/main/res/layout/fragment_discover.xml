<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_v2_background"
    tools:context=".ui.discover.DiscoverFragment">

    <LinearLayout
        android:id="@+id/layoutDiscoverHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_home_v2_avatar"
            android:gravity="center"
            android:text="🌍"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textDiscoverTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/discover_title"
                android:textColor="@color/home_v2_text_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                tools:text="Topluluk Alıntıları" />

            <TextView
                android:id="@+id/textDiscoverSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="4dp"
                android:text="@string/discover_subtitle"
                android:textColor="@color/home_v2_text_secondary"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutDiscoverSearch"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        app:boxBackgroundColor="@color/home_v2_surface"
        app:boxBackgroundMode="filled"
        app:boxCornerRadiusBottomEnd="20dp"
        app:boxCornerRadiusBottomStart="20dp"
        app:boxCornerRadiusTopEnd="20dp"
        app:boxCornerRadiusTopStart="20dp"
        app:boxStrokeColor="@color/home_v2_divider"
        app:endIconMode="clear_text"
        app:endIconTint="@color/home_v2_text_secondary"
        app:hintEnabled="false"
        app:hintTextColor="@color/home_v2_hint"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutDiscoverHeader"
        app:startIconDrawable="@drawable/ic_search"
        app:startIconTint="@color/home_v2_text_secondary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editDiscoverSearch"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="center_vertical"
            android:hint="@string/search_discover"
            android:includeFontPadding="false"
            android:inputType="text|textNoSuggestions"
            android:maxHeight="48dp"
            android:maxLines="1"
            android:minHeight="48dp"
            android:overScrollMode="never"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            android:scrollHorizontally="true"
            android:scrollbars="none"
            android:singleLine="true"
            android:textColor="@color/home_v2_text_primary"
            android:textColorHint="@color/home_v2_hint" />
    </com.google.android.material.textfield.TextInputLayout>

    <HorizontalScrollView
        android:id="@+id/scrollDiscoverFilters"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutDiscoverSearch">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupDiscoverFilters"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:chipSpacingHorizontal="8dp"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDiscoverAll"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/filter_all"
                android:textColor="@color/quote_filter_chip_text"
                android:textSize="13sp"
                app:checkedIconTint="@color/quote_filter_chip_icon"
                app:chipBackgroundColor="@color/quote_filter_chip_background"
                app:chipStrokeColor="@color/quote_filter_chip_stroke"
                app:chipStrokeWidth="1dp"
                app:chipMinHeight="36dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDiscoverMovie"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_movie"
                android:textColor="@color/quote_filter_chip_text"
                android:textSize="13sp"
                app:checkedIconTint="@color/quote_filter_chip_icon"
                app:chipBackgroundColor="@color/quote_filter_chip_background"
                app:chipStrokeColor="@color/quote_filter_chip_stroke"
                app:chipStrokeWidth="1dp"
                app:chipMinHeight="36dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDiscoverSeries"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_series"
                android:textColor="@color/quote_filter_chip_text"
                android:textSize="13sp"
                app:checkedIconTint="@color/quote_filter_chip_icon"
                app:chipBackgroundColor="@color/quote_filter_chip_background"
                app:chipStrokeColor="@color/quote_filter_chip_stroke"
                app:chipStrokeWidth="1dp"
                app:chipMinHeight="36dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDiscoverBook"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_book"
                android:textColor="@color/quote_filter_chip_text"
                android:textSize="13sp"
                app:checkedIconTint="@color/quote_filter_chip_icon"
                app:chipBackgroundColor="@color/quote_filter_chip_background"
                app:chipStrokeColor="@color/quote_filter_chip_stroke"
                app:chipStrokeWidth="1dp"
                app:chipMinHeight="36dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDiscoverSpoiler"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_spoiler"
                android:textColor="@color/quote_filter_chip_text"
                android:textSize="13sp"
                app:checkedIconTint="@color/quote_filter_chip_icon"
                app:chipBackgroundColor="@color/quote_filter_chip_background"
                app:chipStrokeColor="@color/quote_filter_chip_stroke"
                app:chipStrokeWidth="1dp"
                app:chipMinHeight="36dp" />
        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <FrameLayout
        android:id="@+id/layoutDiscoverFeedContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:clipChildren="true"
        android:clipToPadding="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/scrollDiscoverFilters">

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefreshDiscover"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerDiscover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingTop="4dp"
                android:paddingBottom="20dp"
                tools:listitem="@layout/item_quote_home" />
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        <ProgressBar
            android:id="@+id/progressDiscover"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/home_v2_primary" />

        <LinearLayout
            android:id="@+id/layoutEmptyDiscover"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/bg_home_v2_card"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone"
            tools:visibility="visible">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_home_v2_avatar"
                android:contentDescription="@string/discover_empty"
                android:padding="16dp"
                android:src="@drawable/ic_empty_quotes"
                app:tint="@color/home_v2_text_primary" />

            <TextView
                android:id="@+id/textEmptyDiscoverTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="@string/discover_empty"
                android:textColor="@color/home_v2_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textEmptyDiscoverDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:text="@string/discover_empty_detail"
                android:textColor="@color/home_v2_text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/textDiscoverStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="24dp"
            android:accessibilityLiveRegion="polite"
            android:background="@drawable/bg_home_v2_card"
            android:gravity="center"
            android:padding="16dp"
            android:textColor="@color/home_v2_error"
            android:textSize="14sp"
            android:visibility="gone"
            tools:text="Keşfet akışı yüklenemedi."
            tools:visibility="visible" />
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
