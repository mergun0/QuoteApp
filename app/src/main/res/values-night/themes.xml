<resources>
    <style name="Base.Theme.QuoteApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/quote_primary</item>
        <item name="colorPrimaryVariant">@color/quote_primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/quote_secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/quote_background</item>
        <item name="colorOnBackground">@color/quote_text_primary</item>
        <item name="colorSurface">@color/quote_surface</item>
        <item name="colorOnSurface">@color/quote_text_primary</item>
        <item name="colorControlNormal">@color/quote_text_secondary</item>
        <item name="colorControlActivated">@color/quote_primary</item>
        <item name="colorControlHighlight">@color/bottom_nav_ripple</item>
        <item name="android:navigationBarColor">@color/quote_background</item>
        <item name="android:statusBarColor">@color/quote_background</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.QuoteApp.Splash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@drawable/bg_splash</item>
        <item name="android:colorBackground">@color/quote_primary_dark</item>
        <item name="android:statusBarColor">@color/quote_primary_dark</item>
        <item name="android:navigationBarColor">@color/quote_primary_dark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
